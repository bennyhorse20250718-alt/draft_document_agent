# Backend Environment Configuration
# Copy this to .env and fill in your values

# LLM Provider — OpenRouter (OpenAI-compatible API)
# Sign up at https://openrouter.ai and create an API key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your_openrouter_api_key_here
# Model slug from https://openrouter.ai/models (e.g. openai/gpt-4o-mini, google/gemini-flash-1.5)
LLM_MODEL=openai/gpt-4o-mini

# Optional: OpenRouter site metadata (helps with rate limits on free tier)
OPENROUTER_SITE_URL=https://yourdomain.com
OPENROUTER_SITE_NAME=Draft Document AI Agent

# Embedding Model (runs locally via sentence-transformers)
# Options: "all-MiniLM-L6-v2" (fast), "all-mpnet-base-v2" (accurate)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB — Knowledge Base Storage
# CHROMA_MODE: local | cloud | http
CHROMA_MODE=local

# local mode: path to the SQLite/HNSW files on disk
CHROMA_DB_PATH=./data/chroma_db

# cloud mode: Chroma Cloud (https://cloud.trychroma.com)
# Sign up for free at https://cloud.trychroma.com — 1M embeddings / 1 GB free
# CHROMA_MODE=cloud
# CHROMA_CLOUD_API_KEY=chr_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CHROMA_CLOUD_TENANT=your-tenant-id          # found in Chroma Cloud dashboard
# CHROMA_CLOUD_DATABASE=default_database

# http mode: self-hosted ChromaDB server
# CHROMA_MODE=http
# CHROMA_HOST=your-chroma-host.example.com
# CHROMA_PORT=8000

# Document Storage
DOCUMENTS_PATH=./data/documents

# Server
HOST=0.0.0.0
PORT=8000
# For production: set to your actual frontend domain, e.g. https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Optional: proxy settings (only if your server routes outbound traffic through a proxy)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# Draft Export
EXPORT_PATH=./data/exports
